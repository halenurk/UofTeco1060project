# 6. MASTER EXECUTION SUITE
# ==========================================
if __name__ == "__main__":
    np.random.seed(1060)
    p_values = np.linspace(0.05, 0.95, 19)
    start_time = time.time()
    
    print("==================================================")
    print("STARTING ECO1060 ULTIMATE SIMULATION SUITE")
    print("==================================================\n")

    for profile_name, active_params in PARAM_PROFILES.items():
        print(f"\n>>>> COMMENCING SWEEP: {profile_name.upper()} PARAMETERS <<<<\n")

        # --- MODULE 1: ABSOLUTE GRADING ---
        print(f"--> [1/4] Running Absolute Grading Sweep ({profile_name})...")
        abs_data = {'p': [], 't_ta': [], 't_tb': [], 'e_ta': [], 'e_tb': [], 'grids': {}}
        for p in p_values:
            tt_a, tt_b, _ = find_optimal_policy(p, active_params, 'theoretical')
            et_a, et_b, grid = find_optimal_policy(p, active_params, 'empirical')
            abs_data['p'].append(p)
            abs_data['t_ta'].append(tt_a); abs_data['t_tb'].append(tt_b)
            abs_data['e_ta'].append(et_a); abs_data['e_tb'].append(et_b)
            abs_data['grids'][round(p, 2)] = (et_a, et_b, grid)
        
        plot_abs_statics(abs_data, active_params, f'visual_1_absolute_statics_{profile_name}.png')
        plot_filmstrip(abs_data, active_params, "Absolute Grading Equilibria", f'visual_2_absolute_filmstrip_{profile_name}.png')

        # --- MODULE 2: RELATIVE GRADING ---
        print(f"--> [2/4] Running Relative Grading Sweep ({profile_name})...")
        rel_data = {'p': [], 'e_H': [], 'e_L': [], 'grids': {}}
        for p in p_values:
            eh, el, grid = run_relative_simulation(p, active_params)
            rel_data['p'].append(p)
            rel_data['e_H'].append(eh); rel_data['e_L'].append(el)
            rel_data['grids'][round(p, 2)] = grid
            
        plot_rel_tipping(rel_data, active_params, f'visual_4_relative_tipping_{profile_name}.png')
        plot_filmstrip(rel_data, active_params, "Relative Grading Equilibria", f'visual_5_relative_filmstrip_{profile_name}.png')

        # --- MODULE 3: EXAM NOISE ROBUSTNESS ---
        print(f"--> [3/4] Running Noise Robustness Sweep at p=0.50 ({profile_name})...")
        noise_data = {'delta': [], 'e_H': [], 'e_L': []}
        d_vals = np.linspace(1, 30, 30)
        for d in d_vals:
            temp_params = active_params.copy()
            temp_params['delta'] = d
            eh, el, _ = run_relative_simulation(0.50, temp_params)
            noise_data['delta'].append(d)
            noise_data['e_H'].append(eh); noise_data['e_L'].append(el)
            
        plot_robustness(noise_data, active_params, "Robustness Check: Exam Noise", 
                        r"Exam Noise Amplitude ($\pm \delta$)", 'delta', 10.0, f'visual_6_noise_robustness_{profile_name}.png')

        # --- MODULE 4: OMEGA ROBUSTNESS ---
        print(f"--> [4/4] Running Professor Weights Robustness Sweep ({profile_name})...")
        egal_params = active_params.copy()
        egal_params['omega_H'] = 0.5
        egal_params['omega_L'] = 0.5
        
        egal_t_ta = []
        for p in p_values:
            tt_a, _, _ = find_optimal_policy(p, egal_params, 'theoretical')
            egal_t_ta.append(tt_a)
            
        plot_omega_comparison(p_values, abs_data['t_ta'], egal_t_ta, egal_params, f'visual_7_omega_robustness_{profile_name}.png')

        # --- EXPORT DATA ---
        print(f"--> Exporting CSV records ({profile_name})...")
        with open(f'data_absolute_{profile_name}.csv', 'w', newline='') as f:
            w = csv.writer(f)
            w.writerow(['p', 'Theo_TA', 'Theo_TB', 'Emp_TA', 'Emp_TB', 'Egal_Theo_TA'])
            for i in range(len(p_values)):
                w.writerow([round(p_values[i], 2), abs_data['t_ta'][i], abs_data['t_tb'][i], 
                            abs_data['e_ta'][i], abs_data['e_tb'][i], egal_t_ta[i]])
                
        with open(f'data_relative_{profile_name}.csv', 'w', newline='') as f:
            w = csv.writer(f)
            w.writerow(['p', 'High_Effort', 'Low_Effort'])
            for i in range(len(p_values)):
                w.writerow([round(p_values[i], 2), rel_data['e_H'][i], rel_data['e_L'][i]])

    elapsed = time.time() - start_time
    print(f"\n==================================================")
    print(f"SUCCESS! Entire catalog generated in {elapsed:.1f} seconds.")
    print("==================================================")