# ==========================================
# 2. UNIVERSAL HELPER FUNCTIONS
# ==========================================
def add_metadata_stamp(fig, params, x_pos=1.02, y_pos=0.5):
    """Universal stamp that dynamically reads the active parameter profile."""
    stamp_text = (
        f"$\\bf{{Framework:}}$ {params['utility_type']}\n"
        "------------------\n"
        f"$\\bf{{Payoffs:}}$ $V_A={params['V_A']}$, $V_B={params['V_B']}$, $V_C={params['V_C']}$\n"
        f"$\\bf{{Costs:}}$ $C_H={params['C_H']}$, $C_L={params['C_L']}$\n"
        f"$\\bf{{Skill (\\theta):}}$ $\\theta_H={params['theta_H']}$, $\\theta_L={params['theta_L']}$\n"
        f"$\\bf{{Prof\\ Weights:}}$ $\\omega_H={params['omega_H']}$, $\\omega_L={params['omega_L']}$\n"
        "------------------\n"
        "$\\bf{Production\\ Function}$\n"
        f"$S = {params['alpha']}e + {params['beta']}\\theta + {params['base_boost']} \\pm {params['delta']}$\n"
        "------------------\n"
        "$\\bf{Relative\\ Quotas}$\n"
        f"$q_A={params['q_A']}$, $q_B={params['q_B']}$\n"
    )
    fig.text(x_pos, y_pos, stamp_text, fontsize=10, va='center', ha='left',
             bbox=dict(facecolor='#f8f9fa', edgecolor='#ced4da', boxstyle='round,pad=0.8', alpha=0.9))

def expected_prob(threshold, effort, theta, params):
    base_score = params['alpha'] * effort + params['beta'] * theta + params['base_boost']
    target_noise = threshold - base_score
    if target_noise <= -params['delta']: return 1.0
    elif target_noise >= params['delta']: return 0.0
    else: return (params['delta'] - target_noise) / (2 * params['delta'])

def theoretical_best_response(theta, cost_val, T_A, T_B, params):
    EU = {}
    for e in [0, 1]:
        cost = cost_val if e == 1 else 0
        p_A = expected_prob(T_A, e, theta, params)
        p_B = expected_prob(T_B, e, theta, params)
        EU[e] = params['V_C'] + (params['V_A'] - params['V_B']) * p_A + (params['V_B'] - params['V_C']) * p_B - cost
    return 1 if EU[1] > EU[0] else 0

# ==========================================
# 3. ABSOLUTE GRADING ENGINE
# ==========================================
def get_theoretical_W(T_A, T_B, params):
    e_H = theoretical_best_response(params['theta_H'], params['C_H'], T_A, T_B, params)
    e_L = theoretical_best_response(params['theta_L'], params['C_L'], T_A, T_B, params)
    return params['omega_H'] * e_H + params['omega_L'] * e_L

def run_absolute_simulation(T_A, T_B, p_high, params):
    N = params['N']
    is_high = np.zeros(N, dtype=bool)
    num_high = int(round(N * p_high))
    is_high[:num_high] = True
    
    thetas = np.where(is_high, params['theta_H'], params['theta_L'])
    costs = np.where(is_high, params['C_H'], params['C_L'])
    Q_table = np.ones((N, 2)) * params['V_A']
    
    hist_e_H, hist_e_L = [], []
    
    for r in range(params['rounds']):
        explore = np.random.rand(N) < params['epsilon']
        efforts = np.where(explore, np.random.choice([0, 1], size=N), np.argmax(Q_table, axis=1))
        
        noise = np.random.uniform(-params['delta'], params['delta'], size=N)
        scores = params['alpha'] * efforts + params['beta'] * thetas + params['base_boost'] + noise
        
        payoffs = np.where(scores >= T_A, params['V_A'], np.where(scores >= T_B, params['V_B'], params['V_C']))
        utils = payoffs - (efforts * costs)
        
        lr = params['learning_rate']
        Q_table[np.arange(N), efforts] = (1 - lr) * Q_table[np.arange(N), efforts] + lr * utils

        if r >= params['rounds'] - 50:
            hist_e_H.append(np.mean(efforts[is_high]) if num_high > 0 else 0)
            hist_e_L.append(np.mean(efforts[~is_high]) if num_high < N else 0)

    e_H_mean, e_L_mean = np.mean(hist_e_H), np.mean(hist_e_L)
    W = params['omega_H'] * e_H_mean + params['omega_L'] * e_L_mean
    
    grid_side = int(np.sqrt(N))
    return W, efforts.reshape((grid_side, grid_side)), e_H_mean, e_L_mean

def find_optimal_policy(p_high, params, mode='empirical'):
    T_A_vals = np.arange(90.0, 35.0, -5.0)
    T_B_vals = np.arange(40.0, 95.0, 5.0)
    
    max_W = -np.inf
    opt_T_A, opt_T_B, best_grid = None, None, None
    
    for t_a in T_A_vals:
        for t_b in T_B_vals:
            if t_b >= t_a: continue
            
            if mode == 'empirical':
                W, grid, _, _ = run_absolute_simulation(t_a, t_b, p_high, params)
            else:
                W = get_theoretical_W(t_a, t_b, params)
                grid = None
            
            if W > max_W + 1e-6:
                max_W, opt_T_A, opt_T_B, best_grid = W, t_a, t_b, grid
            elif abs(W - max_W) < 1e-6:
                if opt_T_A is None or t_a < opt_T_A:
                    opt_T_A, opt_T_B, best_grid = t_a, t_b, grid
                    
    return opt_T_A, opt_T_B, best_grid

# ==========================================
# 4. RELATIVE GRADING ENGINE
# ==========================================
def run_relative_simulation(p_high, params):
    N = params['N']
    is_high = np.zeros(N, dtype=bool)
    num_high = int(round(N * p_high))
    is_high[:num_high] = True
    
    thetas = np.where(is_high, params['theta_H'], params['theta_L'])
    costs = np.where(is_high, params['C_H'], params['C_L'])
    Q_table = np.ones((N, 2)) * params['V_A']
    
    hist_e_H, hist_e_L = [], []
    
    for r in range(params['rounds']):
        explore = np.random.rand(N) < params['epsilon']
        efforts = np.where(explore, np.random.choice([0, 1], size=N), np.argmax(Q_table, axis=1))
        
        noise = np.random.uniform(-params['delta'], params['delta'], size=N)
        scores = params['alpha'] * efforts + params['beta'] * thetas + params['base_boost'] + noise
        
        ranks = np.argsort(np.argsort(scores))
        c_A = int(N * (1 - params['q_A']))
        c_B = int(N * (1 - (params['q_A'] + params['q_B'])))
        
        payoffs = np.where(ranks >= c_A, params['V_A'], np.where(ranks >= c_B, params['V_B'], params['V_C']))
        utils = payoffs - (efforts * costs)
        
        lr = params['learning_rate']
        Q_table[np.arange(N), efforts] = (1 - lr) * Q_table[np.arange(N), efforts] + lr * utils

        if r >= params['rounds'] - 50:
            hist_e_H.append(np.mean(efforts[is_high]) if num_high > 0 else 0)
            hist_e_L.append(np.mean(efforts[~is_high]) if num_high < N else 0)

    grid_side = int(np.sqrt(N))
    return np.mean(hist_e_H), np.mean(hist_e_L), efforts.reshape((grid_side, grid_side))

